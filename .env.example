# 예시 .env 파일 (.env.example)
# 실제 값은 민감정보이므로 절대 저장소에 커밋하지 마세요.

# 테스트 모드 사용 여부 (True/False)
TEST_MODE=True

# --- 실환경 (실계좌) 설정 ---
# 한국투자증권 앱 키 (production)
KIS_APP_KEY=your_production_app_key_here
# 한국투자증권 앱 시크릿 (production)
KIS_APP_SECRET=your_production_app_secret_here
# 계좌번호 앞 8자리 (예: 실제 값은 여기에 입력)
KIS_ACNT_NO=your_production_account_number_here
# 주식 계좌상품코드(뒤 2자리) (예: 01)
KIS_ACNT_PRDT_CD_STK=01
# 선물옵션 계좌상품코드(뒤 2자리) (선택, 미설정 시 선물옵션 잔고 미조회)
KIS_ACNT_PRDT_CD_FNO=03
# API 기본 URL (선택; 기본값은 실전 도메인)
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# --- 모의/테스트 계정 설정 (선택) ---
# 테스트용 앱 키
TEST_KIS_APP_KEY=your_test_app_key_here
# 테스트용 앱 시크릿
TEST_KIS_APP_SECRET=your_test_app_secret_here
# 테스트 계좌번호 앞 8자리 (예: 실제 테스트 계좌 번호를 입력)
TEST_KIS_ACNT_NO=your_test_account_number_here
# 테스트 계좌상품코드(뒤 2자리)
TEST_KIS_ACNT_PRDT_CD=01
# 테스트 API 기본 URL (선택)
TEST_KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# --- OpenDart API (종목 스크리너용) ---
# https://opendart.fss.or.kr 에서 발급
OPENDART_API_KEY=your_opendart_api_key_here

# --- KRX 데이터 서비스 (종목 스크리너용, 2026-02-27 이후 필수) ---
# https://data.krx.co.kr 에서 무료 회원가입 후 사용
# 미설정 시 /api/screener/stocks 비활성화 (PER/PBR/시총 필터 불가)
KRX_ID=your_krx_id_here
KRX_PASSWORD=your_krx_password_here

# --- OpenAI API (AI자문 리포트 생성용) ---
# https://platform.openai.com 에서 발급
# 미설정 시 /api/advisory/*/analyze 비활성화 (데이터 수집은 정상)
OPENAI_API_KEY=your_openai_api_key_here
# 사용할 OpenAI 모델 (기본값: gpt-5.4)
# 예: gpt-5.4, gpt-5.4-mini, o1, o3-mini
OPENAI_MODEL=gpt-5.4

# --- Finnhub API (해외주식 실시간 시세용, 선택) ---
# https://finnhub.io 에서 무료 발급
# 미설정 시 yfinance 2초 폴링(15분 지연)으로 동작
FINNHUB_API_KEY=your_finnhub_api_key_here

# --- KIS HTS ID (체결통보 실시간 수신용, 선택) ---
# 한국투자증권 HTS ID (로그인 ID)
# 미설정 시 체결통보 WS(H0STCNI0) 비활성화, REST 폴링만 동작
KIS_HTS_ID=your_hts_id_here

# --- Database URL (SQLAlchemy, 선택) ---
# 기본값: sqlite:///$HOME/stock-watchlist/app.db
# PostgreSQL 예시: postgresql://user:pass@localhost:5432/stockmanager
# DATABASE_URL=sqlite:////home/app/stock-watchlist/app.db

# 비고:
# - 실제 환경에서는 .env 파일을 프로젝트 루트에 두고, 이 예시 파일을 복사하여 사용하세요:
#     cp .env.example .env
# - 민감정보는 안전한 비밀관리(예: Vault, Docker/K8s Secret)를 사용하세요.
