# Ignore environment files with secrets
.env
.env.local

# 로컬 docker override (개발자 별도 설정 — 운영 image 영향 없음)
docker-compose.override.yml

# macOS
.DS_Store

# IDE
.idea/

# KIS API 토큰 캐시 (보안)
token.dat

# Python
__pycache__/
*.py[cod]

# Virtual env
venv/

# Screener cache
screener_cache.db

# Exported files
*.csv

# Frontend
frontend/node_modules/
frontend/dist/

# SQLAlchemy / Alembic (DB files are user-specific)
*.db.bak
*.db.pre_migration_bak

# Claude Code plans
.claude/plans/

# Terraform
infra/.terraform/
infra/*.tfstate
infra/*.tfstate.backup
infra/.terraform.lock.hcl
*.tfvars
!*.tfvars.example

# Excel 참고 문서
docs/*.xlsx

# AWS pem
scripts/*.pem

# Claude Code 개인 권한 설정
.claude/settings.local.json
